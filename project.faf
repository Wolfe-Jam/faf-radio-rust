faf_version: '3.3'
project:
  name: mcpaas
  goal: Persistent AI context via Radio Protocol — broadcast once, all AIs receive
  main_language: Rust
  version: 0.2.0
  license: MIT
  type: rust_crate
  subtype: websocket_client
  ecosystem: fafb-broadcasting
instant_context:
  tech_stack:
    - Rust
    - tokio
    - tokio-tungstenite
    - serde
    - serde_json
  main_language: Rust
  key_files:
    - Cargo.toml
    - src/lib.rs
    - src/types.rs
    - src/error.rs
ai_instructions:
  priority_order:
    - 1. Read THIS .faf file first
    - 2. Check CLAUDE.md for session context
    - 3. Review Cargo.toml for dependencies
  working_style:
    code_first: true
    explanations: minimal
    quality_bar: zero_errors
    testing: required
commands:
  build: cargo build
  test: cargo test
  lint: cargo clippy
  format: cargo fmt
state:
  phase: production
  version: 0.2.0
  status: green_flag
preferences:
  quality_bar: zero_errors
  commit_style: conventional_emoji
  response_style: concise_code_first
  testing: required
